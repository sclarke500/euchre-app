{
  "name": "@67cards/client",
  "version": "1.0.5",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "cap:sync": "npm run build && cap sync",
    "cap:ios": "npm run build && cap sync ios && cap open ios",
    "cap:android": "npm run build && cap sync android && cap open android",
    "cap:assets": "npx @capacitor/assets generate --iconBackgroundColor '#1e6045' --iconBackgroundColorDark '#1e6045' --splashBackgroundColor '#1e6045' --splashBackgroundColorDark '#1e6045'"
  },
  "dependencies": {
    "@67cards/shared": "*",
    "@capacitor/android": "^7.0.0",
    "@capacitor/app": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@capacitor/screen-orientation": "^7.0.4",
    "@capgo/capacitor-updater": "7.50.1",
    "canvas-confetti": "^1.9.4",
    "pinia": "^3.0.4",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@tsconfig/node24": "^24.0.3",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^24.10.4",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/tsconfig": "^0.8.1",
    "npm-run-all2": "^8.0.4",
    "sass-embedded": "^1.97.2",
    "typescript": "~5.9.3",
    "vite": "^7.3.0",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vue-tsc": "^3.2.2"
  }
}
